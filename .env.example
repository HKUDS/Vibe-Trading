# ─── Backend API ────────────────────────────────────────────────────
API_AUTH_KEY=change-me-to-a-random-string
LOG_LEVEL=info

# ─── Database ───────────────────────────────────────────────────────
DATABASE_URL=sqlite:///data/app.db

# ─── Vibe-Trading Agent ─────────────────────────────────────────────
# If agent container is running, use internal Docker network
# If agent is external, set the full URL
VIBE_TRADING_API_URL=http://agent:8899

# ─── CORS ───────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
# For production with IP: CORS_ORIGINS=http://your-server-ip
# For production with domain: CORS_ORIGINS=https://your-domain.com
CORS_ORIGINS=http://localhost,http://localhost:80

# ─── LLM Provider (for Vibe-Trading Agent) ──────────────────────────
# These go in agent/.env, not here
# OPENAI_API_KEY=sk-...
# TUSHARE_TOKEN=...

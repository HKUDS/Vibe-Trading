    "academic:momentum": [
      {
        "columns_required": [
          "close"
        ],
        "decay_horizon": 60,
        "formula_latex": "\\mathrm{zscore}_{x}\\bigl((\\mathrm{close}_t - \\mathrm{close}_{t-252})/\\mathrm{close}_{t-252} - (\\mathrm{close}_t - \\mathrm{close}_{t-21})/\\mathrm{close}_{t-21}\\bigr)",
        "id": "academic_carhart_mom",
        "min_warmup_bars": 252,
        "nickname": "Carhart 1997 momentum — 12m-1m return",
        "notes": "Carhart (1997) UMD momentum factor. 12-month return minus 1-month return, cross-sectional z-score per date for long-short ranking. Top z-scores = winners. Constructed directly from prices, so this matches the original definition modulo the z-score wrapper. Canonical 252d window; declared decay_horizon=60 due to registry schema cap (le=60); real signal horizon=252.",
        "theme": [
          "momentum"
        ],
        "zoo": "academic"
      },
      {
        "columns_required": [
          "close"
        ],
        "decay_horizon": 21,
        "formula_latex": "\\mathrm{zscore}_{x}\\bigl((\\mathrm{close}_t - \\mathrm{close}_{t-21}) / \\mathrm{close}_{t-21}\\bigr)",
        "id": "academic_mkt_rf",
        "min_warmup_bars": 21,
        "nickname": "[PRICE PROXY] Market factor (Sharpe 1964) — 21d demeaned return",
        "notes": "[PRICE PROXY] for the Sharpe (1964) / Fama-French market factor (MKT-RF). The original definition uses value-weighted market excess returns; here we use a 21-day per-stock total return and cross-sectional z-score per date for long-short ranking. Top z-scores = strong recent winners; bottom = losers.",
        "theme": [
          "momentum"
        ],
        "zoo": "academic"
      }
    ],

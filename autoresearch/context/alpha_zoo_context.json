    "gtja191:microstructure": [
      {
        "columns_required": [
          "close",
          "high",
          "low"
        ],
        "decay_horizon": 1,
        "formula_latex": "(-1 * DELTA(((CLOSE - LOW) - (HIGH - CLOSE)) / (HIGH - LOW), 1))",
        "id": "gtja191_002",
        "min_warmup_bars": 2,
        "nickname": null,
        "notes": "Daily change in close-position-within-range.",
        "theme": [
          "reversal",
          "microstructure"
        ],
        "zoo": "gtja191"
      },
      {
        "columns_required": [
          "close",
          "volume",
          "amount"
        ],
        "decay_horizon": 3,
        "formula_latex": "((RANK(MAX((VWAP-CLOSE),3)) + RANK(MIN((VWAP-CLOSE),3))) * RANK(DELTA(VOLUME,3)))",
        "id": "gtja191_007",
        "min_warmup_bars": 4,
        "nickname": null,
        "notes": "VWAP via A-share amount/volume (equity_cn convention).",
        "theme": [
          "volume",
          "microstructure"
        ],
        "zoo": "gtja191"
      },
      {
        "columns_required": [
          "high",
          "low",
          "volume"
        ],
        "decay_horizon": 7,
        "formula_latex": "SMA(((HIGH+LOW)/2-(DELAY(HIGH,1)+DELAY(LOW,1))/2)*(HIGH-LOW)/VOLUME,7,2)",
        "id": "gtja191_009",
        "min_warmup_bars": 8,
        "nickname": null,
        "notes": "SMA(n=7, m=2) of midpoint change times range / volume.",
        "theme": [
          "volume",
          "microstructure"
        ],
        "zoo": "gtja191"
      },
      {
        "columns_required": [
          "close",
          "high",
          "low",
          "volume"
        ],
        "decay_horizon": 6,
        "formula_latex": "SUM(((CLOSE-LOW)-(HIGH-CLOSE))/(HIGH-LOW)*VOLUME,6)",
        "id": "gtja191_011",
        "min_warmup_bars": 7,
        "nickname": null,
        "notes": "Accumulated money-flow-multiplier × volume over 6 days.",
        "theme": [
          "volume",
          "microstructure"
        ],
        "zoo": "gtja191"
      }
    ],
    "gtja191:momentum": [
